# Pre-configure up to 6 fallback Gemini API Keys
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here
GEMINI_API_KEY_4=your_fourth_gemini_api_key_here
GEMINI_API_KEY_5=your_fifth_gemini_api_key_here
GEMINI_API_KEY_6=your_sixth_gemini_api_key_here

# Groq powers the AI chat features
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Real YouTube account linking (Google Cloud OAuth credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/youtube/oauth2callback
YOUTUBE_VIDEO_FETCH_LIMIT=100

# Optional configuration settings
PORT=3000
GEMINI_MODEL=gemini-2.5-flash
